__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# Coverage artifacts (regenerated each run)
.coverage
coverage.xml
htmlcov/
db.sqlite3
staticfiles/
build/
dist/

# Deploy-host artifacts (never commit): secrets, the virtualenv, and the
# host-specific blue/green state file written by deploy.sh.
.env
.venv/
.deploy-state

# Reference rulebook PDFs are kept local only (large binaries); the distilled
# specs in docs/reference/*.md are tracked instead.
docs/reference/*.pdf

# Playwright e2e video recordings (regenerated each run)
e2e/videos/
